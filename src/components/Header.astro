---
const { page, t, lang } = Astro.props;
const changeLang = lang === 'en' ? 'it' : 'en';
---
<header>
    <div class="navbar">
            <a href="/"><img src="/immagini/completelogonew.png" alt="elena-zen-logo"></a>
        <nav>
            <div id="menucont">
                <ul id="menu">
                    <span style="word-spacing: normal;"><a href="/#aboutme">{t('nav.about')}</a></span>
                    <a href="/#services">{t('nav.solutions')}</a>
                    <a href={`/${lang}/portfolio`}>{t('nav.portfolio')}</a>
                    <a href="/#contacts">{t('nav.contact')}</a>
                </ul>
                <a class="desktop" href={page === 'portfolio' ? `/${changeLang}/portfolio` : page === 'privacy' ? `/${changeLang}/privacy` : `/${changeLang}`}><span class="icon-park--international desktop"></span></a>
            </div>
            <div class="mobilebtn" aria-haspopup="true" aria-controls="menu" aria-expanded="false">
                <label class="ham" for="ham">
                    <input type="checkbox" id="ham" onclick="show()">
                    <span class="line line1"></span>
                    <span class="line line2"></span>
                    <span class="line line3"></span>
                </label>
                <a href={page === 'portfolio' ? `/${changeLang}/portfolio` : page === 'privacy' ? `/${changeLang}/privacy` : `/${changeLang}`} class="mobile"><span class="icon-park--international mobile fix"></span></a>
            </div>
        </nav>
    </div>
</header>
---
import Header from '../../components/Header.astro';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects as projectsData } from '../../data/projects';
import { languages, makeT } from '../../i18n/ui';

export function getStaticPaths() {
  return languages.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = makeT(lang);

const projects = projectsData.map(p => ({
  classes: p.classes,
  title: p.title[lang],
  description: p.description[lang],
  img: p.img,
  alt: p.alt,
  url: p.url,
  readme: p.readme,
  preview: p.preview,
  repo_visibility: p.repo_visibility,
  badges: p.badges
}));

---

<Layout lang={lang} 
	title="Portfolio | Elena Zen · Full-Stack Web Developer" 
	description={t('portfolio.meta-description')}>
	<Header page="portfolio" t={t} lang={lang}/>

    <section id="portfolio">
      <div>
        <h2 class="textcenter" set:html={t('portfolio.title')}></h2>
        <p set:html={t('portfolio.text')}></p><br>
        <div class="tabs">
            <button id="featured-btn" role="tab" class="tab active">{t('tab.featured')}</button>
            <button id="webapp-btn" role="tab" class="tab">{t('tab.webapps')}</button>
            <button id="data-btn" role="tab" class="tab">{t('tab.data')}</button>
            <button id="website-btn" role="tab" class="tab">{t('tab.websites')}</button>
        </div>
        <div class="grid-container">
            <div class="work contrib featured">
              <img src="/project_banners/banner-nod.png" alt='Piattaforma coworking NOTONLYDESK' loading="lazy"/>
              <div style="display:flex; flex-direction: column;">
              <div class="projtext">
                <h4>NOTONLYDESK</h4>
                <div class="badges">
                  <span class="badge python">PYTHON</span>
                  <span class="badge django">DJANGO</span>
                  <span class="badge seo">SEO</span>
                  <span class="badge javascript">JAVASCRIPT</span>
                </div>
                <p set:html={t('nod.text')}></p>
                <div class="buttons" style="justify-content: flex-start">
                <a style="width: min(50%, 300px)" href="https://www.notonlydesk.com/it/"
                class="btn orange "
                target="_blank" rel="noopener">{t('project.discover')}</a>
              </div>
              </div>
              </div>
            </div>
            {projects.map(p => <ProjectCard t={t} {...p} />)}
        </div>
        <div class="portfolio-final center">
          <p set:html={t('portfolio.final')}></p>
          <div class="btncont">
            <a class="btn violet" href={`/${lang}#contacts`} set:html={t('portfolio.cta1')}></a>
            <a class="btn2" href={`/${lang}#services`} set:html={t('portfolio.cta2')}></a>
        </div>
      </div>
    </section>

    <Footer t={t} lang={lang} />
</Layout>